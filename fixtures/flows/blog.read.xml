<project name="blog-read" stack="nextjs" version="0.1.0">
  <import src="../shared/types.xml" as="types" />

  <node id="api.posts.list" type="api-route" flow="blog.read" extends="types:base.api-route">
    <meta>
      <path>app/api/posts/route.ts</path>
      <depends_on>types:db.post</depends_on>
    </meta>
    <input>
      <field name="limit" type="number" required="false" />
      <field name="page" type="number" required="false" />
    </input>
    <output>
      <field name="posts" type="array" required="true" />
    </output>
    <constraint verify="static">Sort by publishedAt descending</constraint>
    <constraint verify="static">Maximum 20 items per page</constraint>
    <test>
      <name>Get posts list default page size</name>
      <given>
        <query>
          <limit>10</limit>
        </query>
      </given>
      <expect>
        <status>200</status>
        <contains>posts</contains>
      </expect>
    </test>
  </node>
</project>
